# Database. Если пусто — используется локальный SQLite файл backend/rovena.db.
# На Railway/Heroku берётся значение из Postgres add-on.
DATABASE_URL=

# CORS: список URL фронтенда через запятую
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional — Sentry для ошибок (без значения ничего не отправляется)
SENTRY_DSN=
